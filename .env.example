APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# Comma-separated list. Keep empty when serving the frontend and API from the same origin.
ALLOWED_ORIGINS=

# Optional overrides
APP_DATA_DIR=data
APP_LOGO_PATH=public/ikf.png
GMAIL_TOKEN_PATH=data/token.json

# Fernet encryption key for SMTP passwords and API keys stored in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Admin API protection token. Set to a long random string in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_ACCESS_TOKEN=

# Worker tuning (optional)
IKF_MAX_BATCH_WORKERS=5
IKF_WORKER_POLL_SECONDS=2

# Optional database override. Leave commented to use SQLite in APP_DATA_DIR.
# DATABASE_URL=sqlite:///data/sql_app.db

# Google OAuth — Sign-In with Google on the login page + Gmail API access.
# Create credentials at console.cloud.google.com > APIs & Services > Credentials.
# VITE_ prefix is required for Vite to embed the value in the frontend bundle.
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

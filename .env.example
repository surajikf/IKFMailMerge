APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# Comma-separated list. Keep empty when serving the frontend and API from the same origin.
ALLOWED_ORIGINS=

# Optional overrides
APP_DATA_DIR=data
APP_LOGO_PATH=public/ikf.png
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=data/token.json

# Optional database override. Leave commented to use SQLite in APP_DATA_DIR.
# DATABASE_URL=sqlite:///data/sql_app.db
